<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>TalentRank AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #07080e;
        --bg2: #0d0f1a;
        --border: rgba(255, 255, 255, 0.07);
        --border2: rgba(255, 255, 255, 0.13);
        --text: #eeeeff;
        --muted: #6c6f8a;
        --muted2: #474a62;
        --accent: #7c6af7;
        --accent2: #a78bfa;
        --accent3: #c4b5fd;
        --gold: #f59e0b;
        --green: #10b981;
        --green2: #34d399;
        --red: #f87171;
        --orange: #fb923c;
        --blue: #60a5fa;
        --glow: rgba(124, 106, 247, 0.35);
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: "Inter", sans-serif;
        font-size: 14px;
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* bg grid */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: 0;
        background-image:
          linear-gradient(rgba(124, 106, 247, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(124, 106, 247, 0.03) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
      }

      /* orbs */
      .orb {
        position: fixed;
        border-radius: 50%;
        filter: blur(110px);
        pointer-events: none;
        z-index: 0;
      }
      .o1 {
        width: 800px;
        height: 800px;
        background: rgba(124, 106, 247, 0.11);
        top: -250px;
        right: -200px;
      }
      .o2 {
        width: 600px;
        height: 600px;
        background: rgba(16, 185, 129, 0.06);
        bottom: -200px;
        left: -150px;
      }
      .o3 {
        width: 350px;
        height: 350px;
        background: rgba(96, 165, 250, 0.05);
        top: 45%;
        left: 28%;
      }

      .wrap {
        position: relative;
        z-index: 1;
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ── NAV ── */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        background: rgba(7, 8, 14, 0.8);
        backdrop-filter: blur(28px);
        border-bottom: 1px solid var(--border);
      }
      .nav-in {
        max-width: 1140px;
        margin: 0 auto;
        padding: 0 24px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo {
        display: flex;
        align-items: center;
        gap: 11px;
        text-decoration: none;
        color: var(--text);
      }
      .logo-mark {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--accent), #818cf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        box-shadow: 0 0 22px var(--glow);
      }
      .logo-name {
        font-family: "Space Grotesk", sans-serif;
        font-weight: 700;
        font-size: 17px;
        letter-spacing: -0.01em;
      }
      .logo-name span {
        color: var(--accent3);
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .chip {
        font-size: 11px;
        font-weight: 500;
        padding: 4px 13px;
        border-radius: 20px;
        background: rgba(124, 106, 247, 0.13);
        border: 1px solid rgba(124, 106, 247, 0.28);
        color: var(--accent3);
      }
      .chip-green {
        background: rgba(16, 185, 129, 0.1);
        border-color: rgba(16, 185, 129, 0.25);
        color: var(--green2);
      }
      .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green2);
        box-shadow: 0 0 8px var(--green2);
        animation: blink 2s ease-in-out infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.4;
        }
      }

      /* ── HERO ── */
      .hero {
        padding: 148px 0 52px;
        text-align: center;
      }
      .pill {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        background: rgba(124, 106, 247, 0.09);
        border: 1px solid rgba(124, 106, 247, 0.22);
        border-radius: 30px;
        padding: 7px 20px;
        margin-bottom: 28px;
        font-size: 12px;
        color: var(--accent3);
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .pill-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent2);
        animation: blink 2s ease-in-out infinite;
      }
      h1 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(2.8rem, 7vw, 5.2rem);
        font-weight: 800;
        line-height: 1.06;
        letter-spacing: -0.03em;
        margin-bottom: 22px;
      }
      h1 em {
        font-style: normal;
        background: linear-gradient(135deg, var(--accent2), #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero-sub {
        color: var(--muted);
        font-size: 17px;
        font-weight: 300;
        max-width: 560px;
        margin: 0 auto 16px;
        line-height: 1.75;
      }

      /* tech badge row */
      .tech-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 48px;
      }
      .tech-badge {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border2);
        border-radius: 8px;
        padding: 6px 12px;
        font-size: 12px;
        color: var(--muted);
      }
      .tech-badge .ico {
        font-size: 14px;
      }

      /* ── GLASS PANEL ── */
      .glass {
        background: rgba(255, 255, 255, 0.032);
        border: 1px solid var(--border2);
        border-radius: 22px;
        backdrop-filter: blur(24px);
        box-shadow:
          0 4px 6px rgba(0, 0, 0, 0.35),
          0 20px 60px rgba(0, 0, 0, 0.25);
      }

      /* ── INPUT GRID ── */
      .input-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
      }
      @media (max-width: 840px) {
        .input-grid {
          grid-template-columns: 1fr;
        }
      }
      .ph {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 22px;
        border-bottom: 1px solid var(--border);
      }
      .ph-left {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .p-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 19px;
        flex-shrink: 0;
      }
      .pi-p {
        background: rgba(124, 106, 247, 0.15);
      }
      .pi-t {
        background: rgba(16, 185, 129, 0.15);
      }
      .p-title {
        font-family: "Space Grotesk", sans-serif;
        font-weight: 600;
        font-size: 15px;
      }
      .p-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 2px;
      }
      .pb {
        padding: 18px 22px;
      }

      textarea,
      input[type="text"] {
        width: 100%;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border2);
        border-radius: 12px;
        color: var(--text);
        font-family: "Inter", sans-serif;
        font-size: 13px;
        line-height: 1.65;
        padding: 13px 15px;
        resize: vertical;
        transition:
          border-color 0.2s,
          box-shadow 0.2s;
      }
      textarea:focus,
      input[type="text"]:focus {
        outline: none;
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(124, 106, 247, 0.12);
      }
      textarea::placeholder,
      input::placeholder {
        color: var(--muted2);
      }
      #jd-ta {
        min-height: 360px;
      }

      /* candidates */
      .c-scroll {
        max-height: 360px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-right: 4px;
      }
      .c-scroll::-webkit-scrollbar {
        width: 4px;
      }
      .c-scroll::-webkit-scrollbar-thumb {
        background: var(--border2);
        border-radius: 4px;
      }
      .c-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border);
        border-radius: 13px;
        padding: 13px;
      }
      .c-top {
        display: flex;
        align-items: center;
        gap: 9px;
        margin-bottom: 9px;
      }
      .c-num {
        font-size: 10px;
        color: var(--muted2);
        font-weight: 700;
        min-width: 20px;
      }
      .c-top input {
        flex: 1;
        padding: 7px 12px;
        font-size: 13px;
      }
      .btn-rm {
        width: 29px;
        height: 29px;
        border-radius: 8px;
        flex-shrink: 0;
        background: rgba(248, 113, 113, 0.1);
        border: 1px solid rgba(248, 113, 113, 0.2);
        color: var(--red);
        cursor: pointer;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
      }
      .btn-rm:hover {
        background: rgba(248, 113, 113, 0.22);
      }
      .c-card textarea {
        min-height: 80px;
        font-size: 12.5px;
      }
      .btn-add {
        width: 100%;
        margin-top: 12px;
        background: rgba(124, 106, 247, 0.07);
        border: 1px dashed rgba(124, 106, 247, 0.35);
        border-radius: 11px;
        padding: 10px;
        color: var(--accent2);
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
      }
      .btn-add:hover {
        background: rgba(124, 106, 247, 0.14);
        border-color: rgba(124, 106, 247, 0.55);
      }

      /* ── ACTIONS ── */
      .actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        padding: 24px 0;
        flex-wrap: wrap;
      }
      .btn-ghost {
        padding: 11px 24px;
        border-radius: 12px;
        background: transparent;
        border: 1px solid var(--border2);
        color: var(--muted);
        font-size: 13px;
        font-family: "Inter", sans-serif;
        cursor: pointer;
        transition: all 0.2s;
      }
      .btn-ghost:hover:not(:disabled) {
        color: var(--text);
        background: rgba(255, 255, 255, 0.05);
      }
      .btn-ghost:disabled {
        opacity: 0.4;
        cursor: not-allowed;
      }
      .btn-main {
        padding: 14px 38px;
        border-radius: 13px;
        background: linear-gradient(135deg, var(--accent), #818cf8);
        border: none;
        color: #fff;
        font-family: "Space Grotesk", sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        box-shadow:
          0 0 40px var(--glow),
          0 4px 14px rgba(0, 0, 0, 0.4);
        transition: all 0.25s;
        display: flex;
        align-items: center;
        gap: 10px;
      }
      .btn-main:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow:
          0 0 70px var(--glow),
          0 8px 24px rgba(0, 0, 0, 0.4);
      }
      .btn-main:disabled {
        opacity: 0.55;
        cursor: not-allowed;
        transform: none;
      }

      /* ── LOADING ── */
      .loading {
        display: none;
        text-align: center;
        padding: 64px 20px;
      }
      .loading.show {
        display: block;
      }
      .spin {
        width: 54px;
        height: 54px;
        border-radius: 50%;
        border: 3px solid var(--border2);
        border-top-color: var(--accent);
        animation: spin 0.8s linear infinite;
        margin: 0 auto 20px;
      }
      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }
      .load-h {
        font-family: "Space Grotesk", sans-serif;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 8px;
      }
      .load-s {
        color: var(--muted);
        font-size: 13px;
      }
      .dots span {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent2);
        margin: 0 3px;
        animation: db 1.4s ease-in-out infinite;
      }
      .dots span:nth-child(2) {
        animation-delay: 0.2s;
      }
      .dots span:nth-child(3) {
        animation-delay: 0.4s;
      }
      @keyframes db {
        0%,
        80%,
        100% {
          transform: translateY(0);
        }
        40% {
          transform: translateY(-10px);
        }
      }

      /* ── ERROR ── */
      .err {
        background: rgba(248, 113, 113, 0.08);
        border: 1px solid rgba(248, 113, 113, 0.25);
        border-radius: 14px;
        padding: 16px 20px;
        margin: 8px 0;
        color: #fca5a5;
        font-size: 13px;
        display: none;
      }
      .err.show {
        display: block;
      }

      /* ── JD SKILLS STRIP ── */
      .jd-skills-strip {
        background: rgba(124, 106, 247, 0.06);
        border: 1px solid rgba(124, 106, 247, 0.2);
        border-radius: 14px;
        padding: 14px 18px;
        margin-bottom: 20px;
        display: none;
      }
      .jd-skills-strip.show {
        display: block;
      }
      .jd-strip-label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: var(--accent3);
        margin-bottom: 10px;
      }
      .jd-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .jd-tag {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        background: rgba(124, 106, 247, 0.12);
        border: 1px solid rgba(124, 106, 247, 0.25);
        color: var(--accent3);
      }

      /* ── RESULTS ── */
      .res-wrap {
        padding-bottom: 80px;
      }
      .res-head {
        text-align: center;
        padding: 14px 0 38px;
      }
      .res-ey {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--gold);
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 12px;
        background: rgba(245, 158, 11, 0.09);
        border: 1px solid rgba(245, 158, 11, 0.2);
        border-radius: 20px;
        padding: 5px 15px;
      }
      .res-h2 {
        font-family: "Space Grotesk", sans-serif;
        font-size: 2.3rem;
        font-weight: 800;
        letter-spacing: -0.02em;
      }
      .res-list {
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      /* ── RESULT CARD ── */
      .rc {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border2);
        border-radius: 24px;
        padding: 28px 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        animation: su 0.45s ease both;
      }
      @keyframes su {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .rc:nth-child(1) {
        animation-delay: 0.04s;
      }
      .rc:nth-child(2) {
        animation-delay: 0.1s;
      }
      .rc:nth-child(3) {
        animation-delay: 0.16s;
      }
      .rc:nth-child(4) {
        animation-delay: 0.22s;
      }
      .rc:nth-child(5) {
        animation-delay: 0.28s;
      }
      .rc.r1 {
        border-color: rgba(245, 158, 11, 0.35);
        box-shadow:
          0 0 60px rgba(245, 158, 11, 0.07),
          0 4px 6px rgba(0, 0, 0, 0.3);
      }
      .rc::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(124, 106, 247, 0.045) 0%,
          transparent 55%
        );
        pointer-events: none;
      }
      .top-badge {
        position: absolute;
        top: 0;
        right: 0;
        background: linear-gradient(135deg, var(--gold), #d97706);
        color: #fff;
        font-size: 10px;
        font-weight: 800;
        padding: 6px 17px;
        border-radius: 0 24px 0 13px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .rc-hd {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        margin-bottom: 17px;
        flex-wrap: wrap;
      }
      .rc-inf {
        display: flex;
        align-items: center;
        gap: 17px;
      }
      .rc-num {
        width: 58px;
        height: 58px;
        border-radius: 17px;
        flex-shrink: 0;
        background: linear-gradient(135deg, var(--accent), #818cf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Space Grotesk", sans-serif;
        font-size: 23px;
        font-weight: 800;
        color: #fff;
      }
      .rc-num.gld {
        background: linear-gradient(135deg, var(--gold), #d97706);
      }
      .rc-nm {
        font-family: "Space Grotesk", sans-serif;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 7px;
      }
      .rb {
        display: inline-block;
        padding: 3px 13px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 700;
        border: 1px solid;
        letter-spacing: 0.02em;
      }
      .rb-s {
        background: rgba(16, 185, 129, 0.12);
        color: var(--green2);
        border-color: rgba(16, 185, 129, 0.3);
      }
      .rb-g {
        background: rgba(124, 106, 247, 0.12);
        color: var(--accent3);
        border-color: rgba(124, 106, 247, 0.3);
      }
      .rb-p {
        background: rgba(251, 146, 60, 0.12);
        color: var(--orange);
        border-color: rgba(251, 146, 60, 0.3);
      }
      .rb-w {
        background: rgba(248, 113, 113, 0.12);
        color: var(--red);
        border-color: rgba(248, 113, 113, 0.3);
      }

      .rc-sc {
        text-align: right;
        flex-shrink: 0;
      }
      .big-sc {
        font-family: "Space Grotesk", sans-serif;
        font-size: 60px;
        font-weight: 800;
        line-height: 1;
      }
      .sc-g {
        color: var(--green2);
      }
      .sc-b {
        color: var(--blue);
      }
      .sc-o {
        color: var(--orange);
      }
      .sc-r {
        color: var(--red);
      }
      .sc-lbl {
        font-size: 10px;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      /* similarity badge */
      .sim-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(96, 165, 250, 0.1);
        border: 1px solid rgba(96, 165, 250, 0.2);
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        color: var(--blue);
        margin-top: 5px;
      }

      .rc-sum {
        font-size: 13.5px;
        color: rgba(238, 238, 255, 0.82);
        line-height: 1.75;
        border-left: 3px solid rgba(124, 106, 247, 0.45);
        padding-left: 15px;
        margin-bottom: 20px;
        font-style: italic;
      }

      .bars {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 20px;
      }
      .b-top {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        margin-bottom: 5px;
      }
      .b-lbl {
        color: var(--muted);
      }
      .b-val {
        font-weight: 600;
      }
      .bt {
        height: 5px;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 5px;
        overflow: hidden;
      }
      .bf {
        height: 100%;
        border-radius: 5px;
        width: 0;
        transition: width 1s ease;
      }
      .bg {
        background: linear-gradient(90deg, #10b981, #34d399);
      }
      .bb {
        background: linear-gradient(90deg, #3b82f6, #60a5fa);
      }
      .bo {
        background: linear-gradient(90deg, #ea580c, #fb923c);
      }
      .br {
        background: linear-gradient(90deg, #dc2626, #f87171);
      }

      .sk-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 18px;
      }
      @media (max-width: 600px) {
        .sk-cols,
        .sg-cols {
          grid-template-columns: 1fr;
        }
      }
      .sk-lbl {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin-bottom: 9px;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .sl-g {
        color: var(--green2);
      }
      .sl-r {
        color: var(--red);
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }
      .tag {
        font-size: 11px;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid;
      }
      .ty {
        background: rgba(16, 185, 129, 0.1);
        color: var(--green2);
        border-color: rgba(16, 185, 129, 0.3);
      }
      .tn {
        background: rgba(248, 113, 113, 0.1);
        color: var(--red);
        border-color: rgba(248, 113, 113, 0.3);
      }
      .t0 {
        background: transparent;
        color: var(--muted2);
        border-color: var(--border);
      }

      .sg-cols {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
