      }
      .toast.show {
        transform: translateY(0);
        opacity: 1;
      }
      .toast.ok {
        border-color: rgba(16, 185, 129, 0.4);
      }
      .toast.bad {
        border-color: rgba(248, 113, 113, 0.4);
