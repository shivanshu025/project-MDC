      /* TOAST */
      .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        background: rgba(13, 15, 26, 0.96);
        border: 1px solid var(--border2);
        border-radius: 13px;
        padding: 13px 20px;
        font-size: 13px;
