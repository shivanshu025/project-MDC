        border-radius: 7px;
        width: 24px;
        height: 24px;
        cursor: pointer;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.2s;
      }
      .btn-rm-pdf:hover {
        background: rgba(248, 113, 113, 0.25);
      }
      .btn-parse {
        margin-top: 12px;
        width: 100%;
        padding: 10px;
