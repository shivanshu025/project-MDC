        border-radius: 6px;
      }
    </style>
  </head>
  <body>
    <div class="o1 orb"></div>
    <div class="o2 orb"></div>
    <div class="o3 orb"></div>

    <!-- NAV -->
    <nav>
      <div class="nav-in">
        <a class="logo" href="#">
          <div class="logo-mark">🧠</div>
          <div class="logo-name">Talent<span>Rank</span> AI</div>
        </a>
        <div class="nav-right">
          <div class="chip chip-green">
            <span class="status-dot"></span> Python AI
          </div>
          <div class="chip">✦ TF-IDF · Cosine Similarity</div>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <div class="wrap">
      <div class="hero">
        <div class="pill">
          <span class="pill-dot"></span>AI-Powered Candidate Ranking
        </div>
        <h1>Find the <em>perfect hire</em><br />in seconds.</h1>
        <p class="hero-sub">
          Paste a job description and resumes. The Python AI engine scores,
          ranks and explains every candidate .
        </p>
        <div class="tech-row">
          <div class="tech-badge"><span class="ico">🐍</span> Python Flask</div>
          <div class="tech-badge">
            <span class="ico">🤖</span> scikit-learn TF-IDF
          </div>
          <div class="tech-badge">
            <span class="ico">📐</span> Cosine Similarity
          </div>
          <!-- <div class="tech-badge"><span class="ico">🔒</span> Runs 100% offline</div> -->
          <div class="tech-badge">
            <span class="ico">⚡</span> No API key needed
          </div>
        </div>
      </div>

      <!-- INPUTS -->
      <div class="input-grid">
        <div class="glass">
          <div class="ph">
            <div class="ph-left">
              <div class="p-icon pi-p">💼</div>
              <div>
                <div class="p-title">Job Description</div>
                <div class="p-sub">What are you hiring for?</div>
              </div>
            </div>
          </div>
          <div class="pb">
            <textarea
              id="jd-ta"
              placeholder="Paste the full job description — role, responsibilities, required skills, experience level, nice-to-haves…"
            ></textarea>
          </div>
        </div>

        <div class="glass">
          <div class="ph">
            <div class="ph-left">
              <div class="p-icon pi-t">👥</div>
              <div>
                <div class="p-title">Candidates</div>
                <div class="p-sub" id="c-count">1 resume</div>
              </div>
            </div>
          </div>
          <div class="pb">
            <div class="c-scroll" id="c-list"></div>
            <button class="btn-add" onclick="addC()">＋ Add Candidate</button>
          </div>
        </div>
      </div>

      <!-- PDF UPLOAD -->
      <div class="glass pdf-section">
        <div class="ph">
          <div class="ph-left">
            <div class="p-icon" style="background: rgba(245, 158, 11, 0.15)">
              📄
            </div>
            <div>
              <div class="p-title">Upload Resume PDFs</div>
              <div class="p-sub">
                Drop multiple PDFs — text is extracted automatically
              </div>
            </div>
          </div>
        </div>
        <div class="pb">
          <div
            class="pdf-drop"
            id="pdf-drop"
            ondragover="onDragOver(event)"
            ondragleave="onDragLeave(event)"
            ondrop="onDrop(event)"
          >
            <input
              type="file"
              id="pdf-input"
              accept=".pdf"
              multiple
              onchange="onFileChange(event)"
            />
            <div class="pdf-drop-icon">📂</div>
            <div class="pdf-drop-text">
              <strong>Click to browse</strong> or drag &amp; drop PDF files
              here<br />
              <span style="font-size: 11px"
                >Multiple files supported · Text is extracted on the
                server</span
              >
            </div>
          </div>
          <div class="pdf-file-list" id="pdf-file-list"></div>
          <button
            class="btn-parse"
            id="btn-parse"
            disabled
            onclick="parsePdfs()"
          >
            <span id="parse-icon">⚡</span
            ><span id="parse-label">Extract &amp; Add Candidates</span>
          </button>
        </div>
      </div>

      <!-- ACTIONS -->
      <div class="actions">
        <button class="btn-ghost" id="sbtn" onclick="loadSample()">
          📄 Try sample data
        </button>
        <button class="btn-main" id="rbtn" onclick="doRank()">
          <span id="rbi">🚀</span><span id="rbl">Rank with Python AI</span>
        </button>
      </div>

      <div class="err" id="err"></div>

      <!-- JD SKILLS STRIP -->
      <div class="jd-skills-strip" id="jd-strip">
        <div class="jd-strip-label">
          🔍 Skills extracted from job description
        </div>
        <div class="jd-tags" id="jd-tags"></div>
      </div>

      <!-- LOADING -->
      <div class="loading" id="loading">
        <div class="spin"></div>
        <div class="load-h">Python AI analyzing candidates…</div>
        <div class="dots" style="margin: 10px 0">
          <span></span><span></span><span></span>
        </div>
        <div class="load-s">
          TF-IDF vectorization · Cosine similarity scoring · Skill extraction
        </div>
      </div>

      <!-- RESULTS -->
      <div id="results"></div>
    </div>

    <!-- <footer>
  TalentRank AI &mdash; Python + scikit-learn &middot; TF-IDF + Cosine Similarity &middot; 100% Free &middot; No data stored
</footer> -->
    <div class="toast" id="toast"></div>

    <script>
      /* ═══════════════════════════ STATE ═══════════════════════════ */
      let cands = [],
        uid = 0;
      addC();

      /* ═══════════════════════════ CANDIDATES ═══════════════════════════ */
      function addC(name = "", resume = "") {
        cands.push({ id: ++uid, name, resume });
        renderC();
      }
      function removeC(id) {
        if (cands.length <= 1) return;
        cands = cands.filter((c) => c.id !== id);
        renderC();
      }
      function updateC(id, f, v) {
        const c = cands.find((x) => x.id === id);
        if (c) c[f] = v;
      }
      function renderC() {
        const list = document.getElementById("c-list");
        list.innerHTML = "";
        cands.forEach((c, i) => {
          const d = document.createElement("div");
          d.className = "c-card";
          d.innerHTML = `
      <div class="c-top">
        <span class="c-num">#${i + 1}</span>
        <input type="text" placeholder="Candidate name" value="${esc(c.name)}" oninput="updateC(${c.id},'name',this.value)"/>
        ${cands.length > 1 ? `<button class="btn-rm" onclick="removeC(${c.id})">✕</button>` : ""}
      </div>
      <textarea placeholder="Paste resume text — experience, skills, education…" oninput="updateC(${c.id},'resume',this.value)">${esc(c.resume)}</textarea>`;
          list.appendChild(d);
        });
        document.getElementById("c-count").textContent =
          cands.length + " resume" + (cands.length > 1 ? "s" : "");
      }
      function esc(s) {
        return String(s)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      /* ═══════════════════════════ SAMPLE ═══════════════════════════ */
      function loadSample() {
        document.getElementById("jd-ta").value = `Senior Full-Stack Engineer

We're building an AI-powered analytics platform and need a senior engineer to own the full stack.

Required:
- 5+ years building production web apps
- Strong React + TypeScript
- Node.js / serverless backends
- PostgreSQL & schema design
- LLM API experience (OpenAI, Anthropic, Gemini)
- Strong product sense & ownership mindset

Nice to have:
- Early startup / 0-to-1 experience
- Python for data pipelines
- Vector databases (pgvector, Pinecone, Weaviate)`;
        cands = [];
        uid = 0;
        addC(
          "Ava Chen",
          `Senior Software Engineer (7 yrs)
Stripe (3 yrs): React/TypeScript dashboards, Node.js serverless on AWS Lambda, PostgreSQL at scale.
Anthropic (1 yr): Built RAG features with OpenAI + Gemini APIs and pgvector embeddings. Shipped 0→1 AI tooling to 200+ employees.
Stanford BS Computer Science.`,
        );
        addC(
          "Marcus Reed",
          `Frontend Engineer (4 yrs)
Shopify (2 yrs): React, TypeScript, component design systems.
Freelance (2 yrs): Vue + Firebase apps for small businesses.
Self-taught. No backend or AI experience yet.`,
        );
        addC(
          "Priya Patel",
          `Full-Stack Engineer (6 yrs)
Datadog (4 yrs): Node.js microservices, Postgres at massive scale, Python data pipelines.
Startup CTO (2 yrs): React + Node.js + OpenAI APIs, shipped chatbot SaaS from 0 to 10k users.
MIT MEng. Ex-founder, deep product instincts.`,
        );
        toast("Sample data loaded", "ok");
      }

      /* ═══════════════════════════ RANK ═══════════════════════════ */
      async function doRank() {
        const jd = document.getElementById("jd-ta").value.trim();
        if (!jd) {
          toast("Please add a job description", "bad");
          return;
        }
        const valid = cands.filter((c) => c.name.trim() && c.resume.trim());
        if (!valid.length) {
          toast("Add at least one candidate with name + resume", "bad");
          return;
        }

        setLoading(true);
        hideErr();
        document.getElementById("results").innerHTML = "";
        document.getElementById("jd-strip").className = "jd-skills-strip";

        try {
          const res = await fetch("/api/rank", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              job_description: jd,
              candidates: valid.map((c) => ({
                name: c.name,
                resume: c.resume,
              })),
            }),
          });
          if (!res.ok) {
            const e = await res.json().catch(() => ({}));
            throw new Error(e.error || `Server error ${res.status}`);
          }
          const data = await res.json();

          // show extracted JD skills
          if (data.jd_skills_extracted && data.jd_skills_extracted.length) {
            const strip = document.getElementById("jd-strip");
            const tagsEl = document.getElementById("jd-tags");
            tagsEl.innerHTML = data.jd_skills_extracted
              .map((s) => `<span class="jd-tag">${esc(s)}</span>`)
              .join("");
            strip.className = "jd-skills-strip show";
          }

          renderResults(data.rankings || []);
          toast(
            `Ranked ${(data.rankings || []).length} candidate${(data.rankings || []).length > 1 ? "s" : ""}! ✓`,
            "ok",
          );
          setTimeout(
            () =>
              document
                .getElementById("results")
                .scrollIntoView({ behavior: "smooth", block: "start" }),
            120,
          );
        } catch (e) {
          if (e.message.includes("fetch") || e.message.includes("Failed")) {
            showErr(
              "⚠ Cannot connect to Python backend. Make sure you ran: python app.py",
            );
          } else {
            showErr(e.message || "Something went wrong.");
          }
          toast("Error — see message above", "bad");
        } finally {
          setLoading(false);
        }
      }

      /* ═══════════════════════════ RENDER ═══════════════════════════ */
      function renderResults(rankings) {
        const el = document.getElementById("results");
        if (!rankings.length) {
          el.innerHTML =
            '<p style="text-align:center;color:var(--muted);padding:50px">No results.</p>';
          return;
        }
        el.innerHTML = `
    <div class="res-wrap">
      <div class="res-head">
        <div class="res-ey">🏆 Ranked Results</div>
        <div class="res-h2">Top ${rankings.length} Candidate${rankings.length > 1 ? "s" : ""}</div>
      </div>
      <div class="res-list" id="rlist"></div>
    </div>`;

        const list = document.getElementById("rlist");
        rankings.forEach((r, i) => {
          const card = document.createElement("div");
          card.className = "rc" + (i === 0 ? " r1" : "");
          const sc = sCol(r.overall_score);
          const rc = rCls(r.recommendation);
          const mT =
            (r.matched_skills || [])
              .map((s) => `<span class="tag ty">${esc(s)}</span>`)
              .join("") || '<span class="tag t0">None detected</span>';
          const xT =
            (r.missing_skills || [])
              .map((s) => `<span class="tag tn">${esc(s)}</span>`)
              .join("") || '<span class="tag t0">Full coverage!</span>';
          const str = (r.strengths || [])
            .map(
              (s) => `<li><span class="ab">›</span><span>${esc(s)}</span></li>`,
            )
            .join("");
          const gap = (r.gaps || [])
            .map(
              (s) => `<li><span class="ao">›</span><span>${esc(s)}</span></li>`,
            )
            .join("");
          const bars = [
            { l: "Skills", v: r.skills_score },
            { l: "Experience", v: r.experience_score },
            { l: "Education", v: r.education_score },
          ]
            .map(
              (b) => `
      <div>
        <div class="b-top"><span class="b-lbl">${b.l}</span><span class="b-val ${sCol(b.v)}">${b.v}</span></div>
        <div class="bt"><div class="bf ${bCol(b.v)}" data-w="${b.v}" style="width:0%"></div></div>
      </div>`,
            )
            .join("");

          card.innerHTML = `
      ${i === 0 ? '<div class="top-badge">🏆 Top Pick</div>' : ""}
      <div class="rc-hd">
        <div class="rc-inf">
          <div class="rc-num${i === 0 ? " gld" : ""}">${i + 1}</div>
          <div>
            <div class="rc-nm">${esc(r.candidate_name)}</div>
            <span class="rb ${rc}">${esc(r.recommendation)}</span>
            <div class="sim-badge">🤖 AI similarity: ${r.tfidf_similarity}%</div>
          </div>
        </div>
        <div class="rc-sc">
          <div class="big-sc ${sc}">${r.overall_score}</div>
          <div class="sc-lbl">Match Score</div>
        </div>
      </div>
      <div class="rc-sum">${esc(r.summary)}</div>
      <div class="bars">${bars}</div>
      <div class="sk-cols">
        <div><div class="sk-lbl sl-g">✓ Matched Skills</div><div class="tags">${mT}</div></div>
        <div><div class="sk-lbl sl-r">✗ Missing Skills</div><div class="tags">${xT}</div></div>
      </div>
      <div class="sg-cols">
        <div><div class="sg-lbl sg-b">↑ Strengths</div><ul class="sg-ul">${str}</ul></div>
        <div><div class="sg-lbl sg-o">⚠ Gaps & Risks</div><ul class="sg-ul">${gap}</ul></div>
      </div>`;
          list.appendChild(card);
          requestAnimationFrame(() => {
            card.querySelectorAll(".bf").forEach((b) => {
              setTimeout(
                () => {
                  b.style.width = b.dataset.w + "%";
                },
                80 + i * 60,
              );
            });
          });
        });
      }

      /* ═══════════════════════════ HELPERS ═══════════════════════════ */
      function sCol(s) {
        if (s >= 80) return "sc-g";
        if (s >= 60) return "sc-b";
        if (s >= 40) return "sc-o";
        return "sc-r";
      }
      function bCol(s) {
        if (s >= 80) return "bg";
        if (s >= 60) return "bb";
        if (s >= 40) return "bo";
        return "br";
      }
      function rCls(r) {
        if (r === "Strong Match") return "rb-s";
        if (r === "Good Match") return "rb-g";
        if (r === "Possible Match") return "rb-p";
        return "rb-w";
      }
      function setLoading(on) {
        document.getElementById("loading").className =
          "loading" + (on ? " show" : "");
        document.getElementById("rbtn").disabled = on;
        document.getElementById("sbtn").disabled = on;
        document.getElementById("rbi").textContent = on ? "⏳" : "🚀";
        document.getElementById("rbl").textContent = on
          ? "Analyzing…"
          : "Rank with Python AI";
      }
      function showErr(m) {
        const e = document.getElementById("err");
        e.textContent = m;
        e.className = "err show";
      }
      function hideErr() {
        document.getElementById("err").className = "err";
      }
      function toast(msg, type = "ok") {
        const t = document.getElementById("toast");
        t.textContent = msg;
        t.className = "toast show " + type;
        setTimeout(() => {
          t.className = "toast";
        }, 3400);
      }
      /* ═══════════════════════════ PDF UPLOAD ═══════════════════════════ */
      let pdfFiles = []; // { file: File, status: 'pending'|'ok'|'error', pages: 0, msg: '' }

      function onDragOver(e) {
        e.preventDefault();
        document.getElementById("pdf-drop").classList.add("drag");
      }
      function onDragLeave(e) {
        document.getElementById("pdf-drop").classList.remove("drag");
      }
      function onDrop(e) {
        e.preventDefault();
        document.getElementById("pdf-drop").classList.remove("drag");
        const dropped = Array.from(e.dataTransfer.files).filter(
          (f) => f.type === "application/pdf" || f.name.endsWith(".pdf"),
        );
        if (!dropped.length) {
          toast("Only PDF files are supported", "bad");
          return;
        }
        addPdfFiles(dropped);
      }
      function onFileChange(e) {
        const selected = Array.from(e.target.files);
        addPdfFiles(selected);
        e.target.value = ""; // reset so same file can be re-added
      }
      function addPdfFiles(files) {
        files.forEach((f) => {
          if (
            !pdfFiles.find(
              (p) => p.file.name === f.name && p.file.size === f.size,
            )
          ) {
            pdfFiles.push({ file: f, status: "pending", pages: 0, msg: "" });
          }
        });
        renderPdfList();
      }
      function removePdf(idx) {
        pdfFiles.splice(idx, 1);
        renderPdfList();
      }
      function renderPdfList() {
        const list = document.getElementById("pdf-file-list");
        const btn = document.getElementById("btn-parse");
        list.innerHTML = "";
        pdfFiles.forEach((p, i) => {
          const el = document.createElement("div");
          el.className = "pdf-file-item";
          const statusHtml =
            p.status === "ok"
              ? `<span class="pdf-file-status pfs-ok">✓ ${p.pages}p</span>`
              : p.status === "error"
                ? `<span class="pdf-file-status pfs-err" title="${esc(p.msg)}">✗ Error</span>`
                : `<span class="pdf-file-status pfs-load">Pending</span>`;
          el.innerHTML = `
      <span class="pf-icon">📄</span>
      <span class="pdf-file-name" title="${esc(p.file.name)}">${esc(p.file.name)}</span>
      ${statusHtml}
      <button class="btn-rm-pdf" onclick="removePdf(${i})">✕</button>`;
          list.appendChild(el);
        });
        btn.disabled = pdfFiles.length === 0;
      }

      async function parsePdfs() {
        if (!pdfFiles.length) return;
        const parseBtn = document.getElementById("btn-parse");
        const parseIcon = document.getElementById("parse-icon");
        const parseLabel = document.getElementById("parse-label");

        parseBtn.disabled = true;
        parseIcon.textContent = "⏳";
        parseLabel.textContent = "Extracting text…";

        const fd = new FormData();
        pdfFiles.forEach((p) => fd.append("resumes", p.file));

        try {
          const res = await fetch("/api/parse-pdfs", {
            method: "POST",
            body: fd,
          });
          const data = await res.json();

          if (!res.ok) {
            toast(data.error || "PDF parsing failed", "bad");
            return;
          }

          // Mark statuses
          pdfFiles.forEach((p) => {
            const found = data.parsed.find((d) => d.filename === p.file.name);
            const err = data.errors.find((e) => e.startsWith(p.file.name));
            if (found) {
              p.status = "ok";
              p.pages = found.pages;
            } else if (err) {
              p.status = "error";
              p.msg = err;
            }
          });
          renderPdfList();

          // Add each parsed resume as a candidate card
          if (data.parsed && data.parsed.length) {
            data.parsed.forEach((d) => addC(d.name, d.text));
            toast(
              `✓ Added ${data.parsed.length} resume${data.parsed.length > 1 ? "s" : ""} from PDFs`,
              "ok",
            );
            // Scroll down to candidate list
            setTimeout(
              () =>
                document
                  .getElementById("c-list")
                  .scrollIntoView({ behavior: "smooth", block: "start" }),
              120,
            );
          }
          if (data.errors && data.errors.length) {
            toast(`⚠ ${data.errors.length} file(s) failed — check list`, "bad");
          }
        } catch (e) {
          toast("Cannot reach backend — is python app.py running?", "bad");
        } finally {
          parseBtn.disabled = pdfFiles.length === 0;
          parseIcon.textContent = "⚡";
          parseLabel.textContent = "Extract & Add Candidates";
        }
      }
    </script>
  </body>
</html>
